---
import KeyModSection from './KeyModSection.astro';
import KeyModMediaPlaceholder from './KeyModMediaPlaceholder.astro';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['howItWorks'];
}

const { copy } = Astro.props;
---

<KeyModSection id="how-it-works" eyebrow={copy.eyebrow} title={copy.title} subtitle={copy.subtitle} variant="elevated" centered>
  <KeyModMediaPlaceholder label={copy.diagramLabel} variant="video" />
  <div class="km-steps" style="margin-top: 2rem;">
    {
      copy.steps.map((step, i) => (
        <div class="km-step">
          <span class="km-step__num">{i + 1}</span>
          <h3 class="km-card__title">{step.title}</h3>
          <p class="km-card__body">{step.body}</p>
        </div>
      ))
    }
  </div>
</KeyModSection>
