---
import KeyModSection from './KeyModSection.astro';
import { keymodLinks } from '../../i18n/keymodLanding';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['productLine'];
}

const { copy } = Astro.props;
---

<KeyModSection id="product-line" eyebrow={copy.eyebrow} title={copy.title} variant="elevated" centered narrow>
  <p class="km-body" style="text-align: center;">{copy.body}</p>
  <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 1.5rem;">
    <a href={keymodLinks.minikvm} class="km-btn km-btn--ghost">Mini-KVM →</a>
    <a href={keymodLinks.kvmgo} class="km-btn km-btn--ghost">KVM-GO →</a>
  </div>
</KeyModSection>
