---
import KeyModMedia from './KeyModMedia.astro';
import type { KeymodPovSceneId } from '../../data/keymodPovScenes';

interface Props {
  id: string;
  status: string;
  title?: string;
  body: string;
  sceneId?: KeymodPovSceneId;
  compact?: boolean;
  roadmap?: boolean;
  notice?: string;
  assetSection?: string;
  assetSlot?: string;
  mediaLabel?: string;
  demoLinks?: { label: string; href: string }[];
}

const {
  id,
  status,
  title,
  body,
  sceneId,
  compact = false,
  roadmap = false,
  notice,
  assetSection,
  assetSlot,
  mediaLabel,
  demoLinks,
} = Astro.props;

const showMedia = Boolean(assetSection && assetSlot && mediaLabel);
---

<article
  {id}
  class:list={[
    'km-theater-detail',
    roadmap && 'km-theater-detail--roadmap',
    sceneId && 'km-theater-detail--linked',
    compact && 'km-theater-detail--compact',
    showMedia && 'km-theater-detail--with-media',
  ]}
  data-theater-scene={sceneId}
>
  <span class:list={['km-theater-detail__status', roadmap && 'km-theater-detail__status--roadmap']}>
    {status}
  </span>
  {title && !compact ? <h3 class="km-title km-theater-detail__title">{title}</h3> : null}
  <p class="km-body km-theater-detail__body">{body}</p>
  {notice ? <p class="km-theater-detail__notice">{notice}</p> : null}
  {
    demoLinks && demoLinks.length > 0 ? (
      <p class="km-theater-detail__demos">
        {
          demoLinks.map((link) => (
            <a class="km-theater-detail__demo-link" href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label} ↗
            </a>
          ))
        }
      </p>
    ) : null
  }
  {
    sceneId ? (
      <button type="button" class="km-theater-detail__jump" data-theater-jump={sceneId}>
        View demo ↑
      </button>
    ) : null
  }
  {
    showMedia ? (
      <div class="km-theater-detail__media">
        <KeyModMedia section={assetSection} slot={assetSlot} fallbackLabel={mediaLabel!} />
      </div>
    ) : null
  }
</article>
