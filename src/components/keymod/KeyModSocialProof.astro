---
import KeyModSection from './KeyModSection.astro';
import KeyModInstagramEmbed from './KeyModInstagramEmbed.astro';
import { getKeymodInstagramEmbeds } from '../../data/keymodInstagramEmbeds';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['socialProof'];
}

const { copy } = Astro.props;
const embeds = getKeymodInstagramEmbeds();
---

<KeyModSection id="social-proof" eyebrow={copy.eyebrow} title={copy.title} centered>
  <div class="km-ig-embed-grid">
    {embeds.map((embed) => (
      <KeyModInstagramEmbed embed={embed} />
    ))}
  </div>
  <p class="km-subtitle km-ig-embed-grid__footer">
    <a href="https://www.instagram.com/techxartisan/" target="_blank" rel="noopener noreferrer">
      {copy.followIg} ↗
    </a>
    {' · '}
    <a href="/media/?product=keymod">{copy.viewAllMedia} →</a>
  </p>
</KeyModSection>

<script async src="//www.instagram.com/embed.js"></script>
<script>
  import '../../scripts/keymod-instagram-embeds';
</script>
