---
import KeyModSection from './KeyModSection.astro';
import KeyModMediaPlaceholder from './KeyModMediaPlaceholder.astro';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['skuCompare'];
}

const { copy } = Astro.props;
---

<KeyModSection id="choose-port" eyebrow={copy.eyebrow} title={copy.title} centered>
  <div class="km-grid km-grid--2">
    <article class="km-card">
      <h3 class="km-card__title">{copy.mini.name}</h3>
      <p class="km-card__body">
        <strong>{copy.mini.port}</strong><br />
        {copy.mini.audience}
      </p>
      <p class="km-card__body" style="margin-top: 0.75rem; font-style: italic;">{copy.mini.tagline}</p>
      <KeyModMediaPlaceholder label="Mini dongle photo" />
    </article>
    <article class="km-card">
      <h3 class="km-card__title">{copy.plus.name}</h3>
      <p class="km-card__body">
        <strong>{copy.plus.port}</strong><br />
        {copy.plus.audience}
      </p>
      <p class="km-card__body" style="margin-top: 0.75rem; font-style: italic;">{copy.plus.tagline}</p>
      <KeyModMediaPlaceholder label="Plus dongle photo" />
    </article>
  </div>
  <p class="km-subtitle" style="margin-top: 2rem; text-align: center; max-width: none;">
    {copy.contrastLine}
  </p>
</KeyModSection>
