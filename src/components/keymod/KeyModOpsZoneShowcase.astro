---
import KeyModMediaPlaceholder from './KeyModMediaPlaceholder.astro';
import KeyModComposeSendFlow from './KeyModComposeSendFlow.astro';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  opsZone: KeymodLandingStrings['modesTheater']['opsZone'];
}

const { opsZone } = Astro.props;
const imageWidth = 2400;
const imageHeight = 1080;

/** P0 assets land under public/keymod/rebirth/ops/ — show placeholder until files exist. */
const p0Assets = new Set([
  '/keymod/rebirth/ops/ops-terminal-usb.webp',
  '/keymod/rebirth/ops/ops-terminal-ble.webp',
]);

function isP0Placeholder(src: string): boolean {
  return p0Assets.has(src);
}
---

<div class="km-ops-showcase">
  <header class="km-ops-showcase__intro">
    <h3 class="km-ops-showcase__title">{opsZone.intro.title}</h3>
    <p class="km-ops-showcase__body">{opsZone.intro.body}</p>
  </header>

  <section class="km-ops-showcase__block" aria-labelledby="ops-compose-title">
    <span class="km-ops-showcase__badge">{opsZone.compose.badge}</span>
    <h3 id="ops-compose-title" class="km-ops-showcase__title">{opsZone.compose.title}</h3>
    <p class="km-ops-showcase__body">{opsZone.compose.body}</p>
    <KeyModComposeSendFlow compose={opsZone.compose} />
    {
      opsZone.compose.demoLinks && opsZone.compose.demoLinks.length > 0 ? (
        <p class="km-ops-showcase__demos">
          {
            opsZone.compose.demoLinks.map((link) => (
              <a class="km-ops-showcase__demo-link" href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label} ↗
              </a>
            ))
          }
        </p>
      ) : null
    }
    <button type="button" class="km-theater-detail__jump" data-theater-jump="compose-send">
      View demo ↑
    </button>
  </section>

  <section class="km-ops-showcase__block" aria-labelledby="ops-terminal-title">
    <span class="km-ops-showcase__badge">{opsZone.terminal.badge}</span>
    <h3 id="ops-terminal-title" class="km-ops-showcase__title">{opsZone.terminal.title}</h3>
    <p class="km-ops-showcase__body">{opsZone.terminal.body}</p>

    <div class="km-ops-showcase__transports">
      <article class="km-ops-showcase__transport">
        <h4 class="km-ops-showcase__transport-label">{opsZone.terminal.usb.label}</h4>
        <p class="km-ops-showcase__transport-body">{opsZone.terminal.usb.body}</p>
        {
          isP0Placeholder(opsZone.terminal.usb.imageSrc) ? (
            <KeyModMediaPlaceholder label={opsZone.terminal.usb.mediaLabel} />
          ) : (
            <figure class="km-media km-ops-showcase__figure">
              <img
                class="km-media__img"
                src={opsZone.terminal.usb.imageSrc}
                alt={opsZone.terminal.usb.imageAlt}
                width={imageWidth}
                height={imageHeight}
                loading="lazy"
                decoding="async"
              />
            </figure>
          )
        }
      </article>

      <article class="km-ops-showcase__transport">
        <h4 class="km-ops-showcase__transport-label">{opsZone.terminal.ble.label}</h4>
        <p class="km-ops-showcase__transport-body">{opsZone.terminal.ble.body}</p>
        {
          isP0Placeholder(opsZone.terminal.ble.imageSrc) ? (
            <KeyModMediaPlaceholder label={opsZone.terminal.ble.mediaLabel} />
          ) : (
            <figure class="km-media km-ops-showcase__figure">
              <img
                class="km-media__img"
                src={opsZone.terminal.ble.imageSrc}
                alt={opsZone.terminal.ble.imageAlt}
                width={imageWidth}
                height={imageHeight}
                loading="lazy"
                decoding="async"
              />
            </figure>
          )
        }
      </article>
    </div>

    <p class="km-ops-showcase__notice">{opsZone.terminal.notice}</p>
    <button type="button" class="km-theater-detail__jump" data-theater-jump="terminal">
      View demo ↑
    </button>
  </section>
</div>
