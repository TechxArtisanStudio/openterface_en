---
import KeyModSection from './KeyModSection.astro';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['roadmap'];
}

const { copy } = Astro.props;
---

<KeyModSection id="roadmap" eyebrow={copy.eyebrow} title={copy.title} centered>
  <div class="km-grid km-grid--2">
    <article class="km-card">
      <h3 class="km-card__title">{copy.atLaunchTitle}</h3>
      <ul class="km-card__body" style="margin-top: 1rem; padding-left: 1.25rem;">
        {copy.atLaunchItems.map((item) => <li style="margin-bottom: 0.5rem;">{item}</li>)}
      </ul>
    </article>
    <article class="km-card">
      <h3 class="km-card__title">{copy.comingLaterTitle}</h3>
      <ul class="km-card__body" style="margin-top: 1rem; padding-left: 1.25rem;">
        {copy.comingLaterItems.map((item) => <li style="margin-bottom: 0.5rem;">{item}</li>)}
      </ul>
    </article>
  </div>
</KeyModSection>
