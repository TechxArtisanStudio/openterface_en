---
import KeyModModeDetail from './KeyModModeDetail.astro';
import { keymodLinks } from '../../i18n/keymodLanding';
import { getKeymodAsset } from '../../data/keymodAssets';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  gameZone: KeymodLandingStrings['modesTheater']['gameZone'];
  gamepad: KeymodLandingStrings['modesTheater']['gamepad'];
}

const { gameZone, gamepad } = Astro.props;
const gamepadHero = getKeymodAsset('modes', 'gamepad');
const imageWidth = 2400;
const imageHeight = 1080;
---

<div class="km-game-showcase">
  <div class="km-split km-game-showcase__intro">
    <KeyModModeDetail
      id="mode-gamepad"
      status={gamepad.badge}
      title={gamepad.title}
      body={gamepad.body}
      sceneId="gamepad"
      demoLinks={gamepad.demoLinks}
    />
    {
      gamepadHero?.src ? (
        <figure class="km-media km-game-showcase__figure">
          <img
            class="km-media__img"
            src={gamepadHero.src}
            alt={gamepadHero.alt}
            width={imageWidth}
            height={imageHeight}
            loading="lazy"
            decoding="async"
          />
        </figure>
      ) : (
        <p class="km-media-placeholder">
          <span class="km-media-placeholder__label">[ {gamepad.mediaLabel} ]</span>
        </p>
      )
    }
  </div>

  <section class="km-game-showcase__block" aria-labelledby="game-preset-title">
    <h3 id="game-preset-title" class="km-game-showcase__title">{gameZone.presets.title}</h3>
    <p class="km-game-showcase__body">{gameZone.presets.body}</p>
    <figure class="km-media km-game-showcase__figure">
      <img
        class="km-media__img"
        src={gameZone.presets.imageSrc}
        alt={gameZone.presets.imageAlt}
        width={imageWidth}
        height={imageHeight}
        loading="lazy"
        decoding="async"
      />
    </figure>
  </section>

  <section class="km-game-showcase__block" aria-labelledby="game-editor-title">
    <h3 id="game-editor-title" class="km-game-showcase__title">{gameZone.editor.title}</h3>
    <p class="km-game-showcase__body">{gameZone.editor.body}</p>
    <div class="km-game-showcase__duo">
      {
        gameZone.editor.panels.map((panel) => (
          <figure class="km-media km-game-showcase__figure km-game-showcase__figure--duo">
            <img
              class="km-media__img"
              src={panel.imageSrc}
              alt={panel.imageAlt}
              width={imageWidth}
              height={imageHeight}
              loading="lazy"
              decoding="async"
            />
            <figcaption class="km-game-showcase__caption">{panel.caption}</figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <section class="km-game-showcase__share" aria-labelledby="game-share-title">
    <h3 id="game-share-title" class="km-game-showcase__title">{gameZone.share.title}</h3>
    <p class="km-game-showcase__body">{gameZone.share.body}</p>
  </section>

  <p class="km-game-kvmgo">
    {gameZone.kvmGoNote}
    {' '}
    <a href={keymodLinks.kvmgo}>{gameZone.kvmGoCta} →</a>
  </p>
</div>
