---
import KeyModWordmark from './KeyModWordmark.astro';
import Logo from '../Logo.astro';
import LocaleSwitcher from '../LocaleSwitcher.astro';
import { keymodLinks } from '../../i18n/keymodLanding';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['nav'];
}

const { copy } = Astro.props;
---

<header class="km-nav" data-km-nav-theme="default">
  <div class="km-nav__inner">
    <div class="km-nav__brand-lockup">
      <a href="/" class="km-nav__brand-parent" aria-label="Openterface home">
        <Logo variant="nav" />
      </a>
      <span class="km-nav__brand-sep" aria-hidden="true"></span>
      <a href="/keymod/" class="km-nav__product-link" aria-label="KeyMod">
        <KeyModWordmark size="nav" />
      </a>
    </div>

    <nav class="km-nav__actions" aria-label="KeyMod landing">
      <a
        href={keymodLinks.docs}
        class="km-nav__link"
        target="_blank"
        rel="noopener noreferrer"
        data-analytics-event="docs_click"
        data-analytics-product="keymod"
        data-analytics-placement="keymod_nav_docs"
      >
        {copy.docs}
      </a>
      <a
        href={keymodLinks.crowdSupply}
        class="km-btn km-btn--primary km-nav__cta"
        target="_blank"
        rel="noopener noreferrer"
        data-analytics-event="crowdsupply_click"
        data-analytics-product="keymod"
        data-analytics-placement="keymod_nav"
      >
        {copy.preLaunchCta}
        <img
          class="km-btn__icon km-nav__cta-icon"
          src={keymodLinks.crowdSupplyIcon}
          alt=""
          width="20"
          height="20"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
      </a>
      <div class="km-nav__locale">
        <LocaleSwitcher currentPath="/keymod/" currentSearch={Astro.url.search} />
      </div>
    </nav>
  </div>
</header>

<script>
  import { initKeymodZoneNav } from '../../scripts/keymod-zone-nav';

  initKeymodZoneNav();
  document.addEventListener('astro:page-load', initKeymodZoneNav);
</script>
