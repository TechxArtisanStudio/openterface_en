---
import KeyModMedia from './KeyModMedia.astro';

interface Props {
  badge: string;
  title: string;
  body: string;
  mediaLabel: string;
  assetSection?: string;
  assetSlot?: string;
  roadmap?: boolean;
  video?: boolean;
  notice?: string;
}

const {
  badge,
  title,
  body,
  mediaLabel,
  assetSection,
  assetSlot,
  roadmap = false,
  video = false,
  notice,
} = Astro.props;
---

<article class:list={['km-mode-block', roadmap && 'km-mode-block--roadmap']}>
  <span class:list={['km-mode-block__badge', roadmap && 'km-mode-block__badge--roadmap']}>{badge}</span>
  <h3 class="km-title km-mode-block__title">{title}</h3>
  <p class="km-body km-mode-block__body">{body}</p>
  {notice ? <p class="km-mode-block__notice">{notice}</p> : null}
  <div class="km-mode-block__media">
    <KeyModMedia
      section={assetSection}
      slot={assetSlot}
      fallbackLabel={mediaLabel}
      variant={video ? 'video' : 'default'}
    />
  </div>
</article>
