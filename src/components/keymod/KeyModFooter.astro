---
import KeyCmdWordmark from './KeyCmdWordmark.astro';
import { keymodLinks } from '../../i18n/keymodLanding';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['footer'];
}

const { copy } = Astro.props;
---

<footer class="km-footer" id="footer">
  <div class="km-footer__inner">
    <div class="km-footer__cta-row">
      <a href="#updates" class="km-btn km-btn--primary">
        {copy.ctaPrimary}
      </a>
      <a href={keymodLinks.keycmd} class="km-btn km-btn--ghost km-footer__keycmd-btn">
        <KeyCmdWordmark size="footer" decorative />
        <span class="sr-only">{copy.ctaKeycmd}</span>
      </a>
      <a href={keymodLinks.docs} class="km-btn km-btn--ghost" target="_blank" rel="noopener noreferrer">
        Docs
      </a>
      <a href={keymodLinks.discord} class="km-btn km-btn--ghost" target="_blank" rel="noopener noreferrer">
        Discord
      </a>
    </div>
    <div class="km-footer__links">
      <a href={keymodLinks.minikvm}>Mini-KVM</a>
      <a href={keymodLinks.kvmgo}>KVM-GO</a>
      <a href={keymodLinks.keycmd}>KeyCmd</a>
    </div>
    <p class="km-footer__legal">{copy.legal}</p>
  </div>
</footer>
