---
import KeyModWordmark from './KeyModWordmark.astro';
import { keymodLinks } from '../../i18n/keymodLanding';
import { getKeymodAsset, getKeymodAssets, heroPropPositions } from '../../data/keymodAssets';
import type { KeymodLandingStrings } from '../../i18n/keymodLanding';

interface Props {
  copy: KeymodLandingStrings['hero'];
}

const { copy } = Astro.props;
const heroAsset = getKeymodAsset('hero', 'center');
const propAssets = getKeymodAssets('hero', 'prop-');
const propsBySlot = Object.fromEntries(propAssets.map((a) => [a.slot, a]));
---

<section class="km-hero km-hero--light" id="hero" aria-labelledby="hero-title">
  <div class="km-hero__props" aria-hidden="true">
    {
      heroPropPositions.map((slot) => {
        const asset = propsBySlot[slot];
        if (!asset?.src) return null;
        return (
          <img
            class={`km-hero__prop km-hero__prop--${slot.replace('prop-', '')}`}
            src={asset.src}
            alt=""
            width="420"
            height="747"
            loading="lazy"
            decoding="async"
          />
        );
      })
    }
  </div>

  <div class="km-hero__content">
    <h1 id="hero-title" class="km-hero__product-name">
      <KeyModWordmark size="hero" />
      <span class="sr-only">{copy.productName}</span>
    </h1>
    <p class="km-hero__tagline">{copy.tagline}</p>

    <div class="km-hero__image-wrap">
      {
        heroAsset?.src ? (
          <img
            class="km-hero__image"
            src={heroAsset.src}
            alt={heroAsset.alt}
            width="800"
            height="800"
            fetchpriority="high"
            decoding="async"
          />
        ) : null
      }
    </div>

    <p class="km-hero__headline">{copy.headline}</p>
    <p class="km-hero__lead">{copy.subhead}</p>
    <p class="km-hero__lead km-hero__lead--scenario">{copy.leadScenario}</p>

    <div class="km-hero__actions">
      <a href={keymodLinks.crowdSupply} class="km-btn km-btn--primary" target="_blank" rel="noopener noreferrer">
        {copy.cta}
      </a>
      <a href={keymodLinks.docs} class="km-btn km-btn--ghost" target="_blank" rel="noopener noreferrer">
        Docs
      </a>
    </div>
  </div>
</section>
