---
import { mainNav } from '../data/navigation';
import Logo from './Logo.astro';
import LocaleSwitcher from './LocaleSwitcher.astro';
import NavDropdown from './NavDropdown.astro';
import ProductsMegaMenu from './ProductsMegaMenu.astro';
import { enNavMobile } from '../i18n/nav';
import { siteConfig } from '../config/site';
import { LOCALE_LABELS, SUPPORTED_LOCALES, switchLocaleUrl, type SiteLocale } from '../lib/locale';

const dropdownSections = mainNav.filter((item) => item.children);
const ecosystemLinks = mainNav.filter((item) => !item.children);
const currentPath = Astro.url.pathname;
const currentSearch = Astro.url.search;
const locale = siteConfig.locale as SiteLocale;
---

<header class="site-header sticky top-0 z-50 bg-primary-dark shadow-md">
  <div class="site-header__inner">
    <div class="site-header__start">
      <a href="/" class="site-header__brand">
        <Logo variant="onPrimary" class="site-header__logo" />
      </a>
      <span class="site-header__suffix" aria-hidden="true"></span>
      <span class="site-header__lead" aria-hidden="true"></span>
    </div>

    <nav class="site-header__nav" aria-label="Main navigation">
      {
        mainNav.map((item) =>
          item.megaMenu ? (
            <ProductsMegaMenu label={item.label} />
          ) : item.children ? (
            <NavDropdown label={item.label} href={item.href} children={item.children} />
          ) : (
            <a
              href={item.href}
              class="site-header__nav-link"
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="site-header__toolbar">
      <LocaleSwitcher
        currentPath={currentPath}
        currentSearch={currentSearch}
        class="hidden sm:block"
      />

      <details class="mobile-nav relative xl:hidden">
        <summary
          class="site-header__icon-btn mobile-nav-toggle"
          aria-label="Open menu"
        >
          <svg class="mobile-nav-icon-open h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
          <svg class="mobile-nav-icon-close hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </summary>

        <div class="mobile-nav-backdrop fixed inset-0 top-[var(--site-header-height)] z-40 bg-black/45"></div>

        <nav
          class="mobile-nav-panel fixed inset-x-0 top-[var(--site-header-height)] z-50 border-b border-gray-200 bg-white shadow-lg"
          aria-label="Mobile navigation"
        >
          <div class="mx-auto max-h-[min(75vh,36rem)] max-w-7xl overflow-y-auto overscroll-contain px-3 py-2 sm:px-4 sm:py-3">
            {
              dropdownSections.map((section) => (
                <div class="mobile-nav-section">
                  {section.href ? (
                    <a href={section.href} class="mobile-nav-section-label mobile-nav-section-label--link">
                      {section.label}
                    </a>
                  ) : (
                    <p class="mobile-nav-section-label">{section.label}</p>
                  )}
                  <div class="mobile-nav-section-links">
                    {
                      section.children?.map((child) => (
                        <a href={child.href} class="mobile-nav-link">{child.label}</a>
                      ))
                    }
                  </div>
                </div>
              ))
            }

            <div class="mobile-nav-section">
              <p class="mobile-nav-section-label">{enNavMobile.ecosystem}</p>
              <div class="mobile-nav-section-links">
                {
                  ecosystemLinks.map((item) => (
                    <a href={item.href} class="mobile-nav-link">{item.label}</a>
                  ))
                }
              </div>
            </div>

            <div class="mobile-nav-section pb-1 sm:hidden">
              <p class="mobile-nav-section-label">Language</p>
              <div class="mobile-nav-section-links">
                {
                  SUPPORTED_LOCALES.map((loc) => (
                    <a
                      href={switchLocaleUrl(currentPath, loc, currentSearch)}
                      class:list={[
                        'mobile-nav-link',
                        loc === locale ? 'font-semibold text-primary-dark' : '',
                      ]}
                    >
                      {LOCALE_LABELS[loc]}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  function closeAllNavDropdowns(except?: Element | null) {
    document.querySelectorAll('.nav-dropdown.is-open, .nav-dropdown[open]').forEach((dropdown) => {
      if (except && dropdown === except) return;
      dropdown.classList.remove('is-open');
      if (dropdown instanceof HTMLDetailsElement) dropdown.open = false;
      const panel = dropdown.querySelector('.nav-dropdown__panel');
      if (panel instanceof HTMLElement) panel.hidden = true;
      dropdown.querySelector('[data-nav-toggle]')?.setAttribute('aria-expanded', 'false');
    });
  }

  function initProductsMegaMenu() {
    document.querySelectorAll('[data-products-mega]').forEach((dropdown) => {
      if (dropdown.dataset.initialized) return;
      dropdown.dataset.initialized = 'true';

      const toggle = dropdown.querySelector('[data-nav-toggle]');
      const panel = dropdown.querySelector('.nav-dropdown__panel');
      let openTimer: ReturnType<typeof setTimeout> | undefined;
      let closeTimer: ReturnType<typeof setTimeout> | undefined;

      const setOpen = (open: boolean) => {
        dropdown.classList.toggle('is-open', open);
        if (panel instanceof HTMLElement) panel.hidden = !open;
        toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
      };

      const scheduleOpen = () => {
        clearTimeout(closeTimer);
        openTimer = setTimeout(() => {
          closeAllNavDropdowns(dropdown);
          setOpen(true);
        }, 120);
      };

      const scheduleClose = () => {
        clearTimeout(openTimer);
        closeTimer = setTimeout(() => setOpen(false), 180);
      };

      dropdown.addEventListener('pointerenter', scheduleOpen);
      dropdown.addEventListener('pointerleave', scheduleClose);
      dropdown.addEventListener('focusin', scheduleOpen);
      dropdown.addEventListener('focusout', (event) => {
        const related = event.relatedTarget;
        if (related instanceof Node && dropdown.contains(related)) return;
        scheduleClose();
      });

      toggle?.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const next = !dropdown.classList.contains('is-open');
        clearTimeout(openTimer);
        clearTimeout(closeTimer);
        if (next) {
          closeAllNavDropdowns(dropdown);
        }
        setOpen(next);
      });
    });
  }

  let navGlobalListenersBound = false;

  function bindNavGlobalListeners() {
    if (navGlobalListenersBound) return;
    navGlobalListenersBound = true;

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      const inside = [...document.querySelectorAll('.nav-dropdown.is-open, .nav-dropdown[open]')].find(
        (dropdown) => dropdown.contains(target),
      );
      if (!inside) closeAllNavDropdowns();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      closeAllNavDropdowns();
    });
  }

  function initNavDropdowns() {
    document.querySelectorAll('.nav-dropdown:not([data-products-mega])').forEach((dropdown) => {
      if (dropdown.dataset.initialized) return;
      dropdown.dataset.initialized = 'true';

      const toggle = dropdown.querySelector('[data-nav-toggle]');
      const panel = dropdown.querySelector('.nav-dropdown__panel');

      const setOpen = (open: boolean) => {
        dropdown.classList.toggle('is-open', open);
        if (dropdown instanceof HTMLDetailsElement) dropdown.open = open;
        if (panel instanceof HTMLElement) panel.hidden = !open;
        toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
      };

      toggle?.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const next = !dropdown.classList.contains('is-open');
        closeAllNavDropdowns(next ? dropdown : null);
        setOpen(next);
      });

      dropdown.addEventListener('toggle', () => {
        if (!(dropdown instanceof HTMLDetailsElement) || !dropdown.open) return;
        document.querySelectorAll('.nav-dropdown[open], .nav-dropdown.is-open').forEach((other) => {
          if (other === dropdown) return;
          if (other instanceof HTMLDetailsElement) other.open = false;
          other.classList.remove('is-open');
          const otherPanel = other.querySelector('.nav-dropdown__panel');
          if (otherPanel instanceof HTMLElement) otherPanel.hidden = true;
          other.querySelector('[data-nav-toggle]')?.setAttribute('aria-expanded', 'false');
        });
      });
    });

    bindNavGlobalListeners();
  }

  function initMobileNav() {
    document.querySelectorAll('.mobile-nav').forEach((details) => {
      if (details.dataset.initialized) return;
      details.dataset.initialized = 'true';

      const backdrop = details.querySelector('.mobile-nav-backdrop');
      const links = details.querySelectorAll('.mobile-nav-link');
      const summary = details.querySelector('summary');

      const setOpen = (open: boolean) => {
        if (!(details instanceof HTMLDetailsElement)) return;
        details.open = open;
        document.body.classList.toggle('overflow-hidden', open);
        summary?.setAttribute('aria-expanded', open ? 'true' : 'false');
        summary?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      };

      details.addEventListener('toggle', () => {
        if (!(details instanceof HTMLDetailsElement)) return;
        setOpen(details.open);
      });

      backdrop?.addEventListener('click', () => setOpen(false));

      links.forEach((link) => {
        link.addEventListener('click', () => setOpen(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && details instanceof HTMLDetailsElement && details.open) {
          setOpen(false);
        }
      });

      setOpen(details instanceof HTMLDetailsElement && details.open);
    });
  }

  initProductsMegaMenu();
  initNavDropdowns();
  initMobileNav();
  document.addEventListener('astro:page-load', () => {
    initProductsMegaMenu();
    initNavDropdowns();
    initMobileNav();
  });
</script>

<style>
  .mobile-nav > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav:not([open]) .mobile-nav-panel,
  .mobile-nav:not([open]) .mobile-nav-backdrop {
    display: none;
  }

  .mobile-nav[open] .mobile-nav-backdrop {
    display: block;
  }

  .mobile-nav[open] .mobile-nav-toggle {
    background-color: rgb(255 255 255 / 0.15);
  }

  .mobile-nav[open] .mobile-nav-icon-open {
    display: none;
  }

  .mobile-nav[open] .mobile-nav-icon-close {
    display: block;
  }

  .mobile-nav-section {
    margin-top: 0.5rem;
    border-top: 1px solid #f3f4f6;
    padding-top: 0.75rem;
  }

  .mobile-nav-section-label {
    display: block;
    padding: 0 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-muted) 85%, transparent);
  }

  .mobile-nav-section-label--link {
    text-decoration: none;
  }

  .mobile-nav-section-label--link:hover,
  .mobile-nav-section-label--link:focus-visible {
    color: var(--color-primary-dark);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .mobile-nav-section-links {
    margin-top: 0.25rem;
    display: flex;
    flex-direction: column;
  }

  .mobile-nav-link {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    border-radius: 0.375rem;
    padding: 0.625rem 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-ink);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link:focus-visible {
    background-color: var(--color-brand-light);
  }

  .mobile-nav-link--home {
    font-size: 1rem;
    font-weight: 600;
  }

  .mobile-nav-link--external {
    color: color-mix(in srgb, var(--color-ink) 88%, var(--color-muted));
  }
</style>
