---
interface Props {
  variant?: 'default' | 'onPrimary' | 'nav';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;
const sizeClass =
  variant === 'nav' ? 'km-nav__openterface-logo' : 'h-8 w-auto max-w-[180px]';
---

<img
  src="/keymod/logo/openterface-wordmark.svg"
  alt="Openterface"
  class:list={[sizeClass, variant === 'onPrimary' && 'brightness-0 invert', className]}
  width="180"
  height="27"
/>
