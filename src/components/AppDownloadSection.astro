---
import OsPlatformIcon from './OsPlatformIcon.astro';
import type { AppDownloadSection } from '../data/apps';

interface Props {
  section: AppDownloadSection;
  headingLevel?: 1 | 2;
}

const { section, headingLevel = 2 } = Astro.props;
const HeadingTag = headingLevel === 1 ? 'h1' : 'h2';

function platformSlug(name: string): string {
  return name.trim().toLowerCase().replace(/\s+/g, '-');
}
---

<section
  class="product-section"
  id={section.id}
  aria-labelledby={`${section.id}-heading`}
>
  <div class="product-section__inner">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <HeadingTag class="section-title" id={`${section.id}-heading`}>
          {section.title}
        </HeadingTag>
        <p class="mt-2 max-w-2xl text-muted">{section.description}</p>
      </div>
      <a
        href={section.docsHref}
        class="text-sm font-semibold text-primary-dark hover:underline shrink-0"
        target="_blank"
        rel="noopener noreferrer"
      >
        {section.docsLabel}
      </a>
    </div>

    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        section.platforms.map((platform) => (
          <article
            id={platformSlug(platform.name) === 'linux' && section.id === 'kvm' ? 'linux' : `${section.id}-${platformSlug(platform.name)}`}
            class="rounded-lg border border-gray-200 bg-white p-5"
          >
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-md bg-brand-light">
                <OsPlatformIcon name={platform.name} />
              </span>
              <h3 class="text-lg font-semibold text-primary-dark">{platform.name}</h3>
            </div>
            <p class="mt-2 text-sm text-muted">{platform.description}</p>
            {platform.downloads.length > 0 ? (
              <ul class="mt-4 space-y-2">
                {platform.downloads.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm font-semibold text-primary-dark hover:underline"
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noopener noreferrer' : undefined}
                    >
                      {link.label} →
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-4 text-sm font-medium text-muted">Coming soon</p>
            )}
            {platform.repo && (
              <p class="mt-3 text-sm text-muted">
                Source:{' '}
                <a
                  href={platform.repo.href}
                  class="font-medium text-primary-dark hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {platform.repo.label}
                </a>
              </p>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
