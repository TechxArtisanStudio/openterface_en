/**
 * Bootstrap Icons brand marks for footer social links (v1.13.1).
 * @see https://icons.getbootstrap.com/
 */
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'h-5 w-5' } = Astro.props;

function resolveIconKey(raw: string): string | null {
  const key = raw.trim().toLowerCase();
  if (key === 'discord') return 'discord';
  if (key === 'reddit') return 'reddit';
  if (key === 'x (twitter)' || key === 'x' || key === 'twitter') return 'twitter-x';
  if (key === 'threads') return 'threads';
  if (key === 'youtube') return 'youtube';
  if (key === 'github') return 'github';
  return null;
}

const iconKey = resolveIconKey(name);
