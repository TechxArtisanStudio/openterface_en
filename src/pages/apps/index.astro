---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppDownloadSection from '../../components/AppDownloadSection.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { appDownloadSections } from '../../data/apps';
---

<BaseLayout
  title="Openterface Apps"
  description="Download open-source Openterface host apps — Openterface KVM for Mini-KVM, KVM-GO, and uConsole; KeyCmd for phone-as-keyboard workflows."
  keywords="Openterface app, KVM software, KeyCmd, QT host app, Android KVM, open source"
  ogImageAlt="Openterface Apps — Openterface KVM and KeyCmd"
  canonicalPath="/apps/"
>
  <DocLinkBanner variant="product" />

  {appDownloadSections.map((section) => <AppDownloadSection section={section} />)}
</BaseLayout>
